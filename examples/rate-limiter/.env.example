# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_CONNECTION_POOL_SIZE=10
REDIS_TIMEOUT_MS=5000
REDIS_RETRY_ATTEMPTS=3

# Server Configuration
PORT=3000
NODE_ENV=development

# Rate Limiter Configuration
# Fallback to local cache when Redis latency exceeds this threshold
REDIS_SLOW_THRESHOLD_MS=100

# Local cache TTL when Redis is slow (in seconds)
LOCAL_CACHE_TTL_SECONDS=5

# Fail open (allow requests) when Redis is unavailable
FAIL_OPEN=true

# Logging Configuration
LOG_LEVEL=info
LOG_PRETTY=true
