# DO NOT commit actual secrets to this file
# Copy to .env and fill in real values for local development

# Stripe Configuration
# Use test mode keys for development: sk_test_...
# NEVER commit live keys (sk_live_...) to source control
STRIPE_API_KEY=sk_test_your_test_key_here

# AWS Configuration
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=PaymentRecords
KMS_KEY_ID=alias/payment-processor-encryption

# AWS Secrets Manager (Production)
# In production, load STRIPE_API_KEY from Secrets Manager instead of .env
SECRETS_MANAGER_SECRET_NAME=payment-processor/stripe-api-key

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Lambda Configuration (for deployed environment)
LAMBDA_TIMEOUT=10
LAMBDA_MEMORY=512
