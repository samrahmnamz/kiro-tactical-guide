{
  "name": "@kiro-examples/resilient-service",
  "version": "1.0.0",
  "description": "Example demonstrating resiliency patterns: circuit breakers, retry with backoff, timeouts, graceful degradation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
