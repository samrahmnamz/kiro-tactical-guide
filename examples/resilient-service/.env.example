# Resilient Service Configuration

# Server
PORT=3000
NODE_ENV=development

# Payment Gateway
PAYMENT_GATEWAY_URL=https://payment.example.com
PAYMENT_TIMEOUT_MS=5000
PAYMENT_MAX_RETRIES=3
PAYMENT_CIRCUIT_THRESHOLD=5
PAYMENT_CIRCUIT_RESET_MS=30000

# Inventory Service
INVENTORY_SERVICE_URL=https://inventory.example.com
INVENTORY_TIMEOUT_MS=3000
INVENTORY_MAX_RETRIES=2
INVENTORY_CIRCUIT_THRESHOLD=3
INVENTORY_CIRCUIT_RESET_MS=15000

# Notification Service
NOTIFICATION_SERVICE_URL=https://notification.example.com
NOTIFICATION_TIMEOUT_MS=2000
NOTIFICATION_MAX_RETRIES=1
NOTIFICATION_CIRCUIT_THRESHOLD=10
NOTIFICATION_CIRCUIT_RESET_MS=60000

# Redis (for caching fallback data)
REDIS_URL=redis://localhost:6379
REDIS_COMMAND_TIMEOUT_MS=1000
REDIS_CONNECT_TIMEOUT_MS=3000

# DynamoDB
DYNAMODB_TABLE_NAME=Orders
DYNAMODB_REQUEST_TIMEOUT_MS=3000
DYNAMODB_CONNECTION_TIMEOUT_MS=1000

# Retry Configuration
RETRY_BASE_DELAY_MS=100
RETRY_MAX_DELAY_MS=5000
RETRY_JITTER=full

# Bulkhead Configuration
PAYMENT_MAX_CONNECTIONS=20
INVENTORY_MAX_CONNECTIONS=15
NOTIFICATION_MAX_CONNECTIONS=10
